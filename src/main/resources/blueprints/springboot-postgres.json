{
  "blueprintId": "springboot-postgres",
  "displayName": "Spring Boot + PostgreSQL (ECS Fargate)",
  "description": "Deploys a Spring Boot application on ECS Fargate with a managed RDS PostgreSQL database, an Application Load Balancer for HTTPS traffic, and a private VPC. Enforces encryption at rest and in transit, least-privilege IAM, and VPC flow logs.",
  "outputType": "TERRAFORM_ONLY",
  "templateFamily": "ecs",
  "terraformProviderVersion": "5.82.0",
  "lastVerifiedDate": "2026-06",
  "techStack": {
    "language": "Java/Kotlin",
    "framework": "Spring Boot",
    "database": "PostgreSQL"
  },
  "awsResources": [
    {
      "type": "VPC",
      "required": true,
      "defaultConfig": {
        "cidr": "10.0.0.0/16"
      }
    },
    {
      "type": "ALB",
      "required": true,
      "defaultConfig": {
        "https_only": true
      }
    },
    {
      "type": "ECS_FARGATE",
      "required": true,
      "defaultConfig": {
        "cpu": 512,
        "memory": 1024
      }
    },
    {
      "type": "RDS_POSTGRES",
      "required": true,
      "defaultConfig": {
        "instance_class": "db.t3.micro",
        "allocated_storage": 20
      }
    },
    {
      "type": "KMS",
      "required": true,
      "defaultConfig": {}
    }
  ],
  "variables": [
    {
      "name": "project_name",
      "description": "Unique name for this deployment (alphanumeric + hyphens)",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "aws_region",
      "description": "AWS region to deploy into",
      "type": "string",
      "default": "us-east-1",
      "required": false
    },
    {
      "name": "aws_profile",
      "description": "AWS CLI profile name (PRODUCTION only)",
      "type": "string",
      "default": "default",
      "required": false
    },
    {
      "name": "environment",
      "description": "Deployment environment tag (e.g. dev, staging, prod)",
      "type": "string",
      "default": "dev",
      "required": false
    },
    {
      "name": "container_image",
      "description": "Full ECR image URI including tag",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "container_port",
      "description": "Port the Spring Boot app listens on",
      "type": "number",
      "default": 8080,
      "required": false
    },
    {
      "name": "task_cpu",
      "description": "ECS task CPU units (256, 512, 1024, 2048, 4096)",
      "type": "number",
      "default": 512,
      "required": false
    },
    {
      "name": "task_memory",
      "description": "ECS task memory in MiB",
      "type": "number",
      "default": 1024,
      "required": false
    },
    {
      "name": "desired_count",
      "description": "Number of ECS task instances to run",
      "type": "number",
      "default": 2,
      "required": false
    },
    {
      "name": "db_name",
      "description": "Name of the PostgreSQL database to create",
      "type": "string",
      "default": "appdb",
      "required": false
    },
    {
      "name": "db_username",
      "description": "PostgreSQL master username",
      "type": "string",
      "default": "dbadmin",
      "required": false
    },
    {
      "name": "db_instance_class",
      "description": "RDS instance type",
      "type": "string",
      "default": "db.t3.micro",
      "required": false
    },
    {
      "name": "db_allocated_storage",
      "description": "Initial RDS storage in GB",
      "type": "number",
      "default": 20,
      "required": false
    },
    {
      "name": "certificate_arn",
      "description": "ACM certificate ARN for ALB HTTPS listener",
      "type": "string",
      "default": null,
      "required": true
    }
  ],
  "securityBaseline": {
    "enableVpcFlowLogs": true,
    "enforceHttps": true
  }
}
