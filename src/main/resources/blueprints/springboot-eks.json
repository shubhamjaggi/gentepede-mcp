{
  "blueprintId": "springboot-eks",
  "displayName": "Spring Boot + PostgreSQL (EKS + Helm)",
  "description": "Deploys a Spring Boot application on Amazon EKS using Helm, with an RDS PostgreSQL database, ALB Ingress Controller for HTTPS, and a private VPC. Generates both Terraform (cluster, RDS, VPC) and a production-ready Helm chart (Deployment, HPA, NetworkPolicy, ResourceQuota).",
  "outputType": "TERRAFORM_K8S",
  "templateFamily": "eks",
  "terraformProviderVersion": "5.82.0",
  "lastVerifiedDate": "2026-06",
  "techStack": {
    "language": "Java/Kotlin",
    "framework": "Spring Boot",
    "database": "PostgreSQL"
  },
  "awsResources": [
    {
      "type": "VPC",
      "required": true,
      "defaultConfig": {
        "cidr": "10.0.0.0/16"
      }
    },
    {
      "type": "EKS_CLUSTER",
      "required": true,
      "defaultConfig": {
        "version": "1.31",
        "node_instance_type": "t3.medium"
      }
    },
    {
      "type": "ALB",
      "required": true,
      "defaultConfig": {
        "https_only": true
      }
    },
    {
      "type": "RDS_POSTGRES",
      "required": true,
      "defaultConfig": {
        "instance_class": "db.t3.micro",
        "allocated_storage": 20
      }
    },
    {
      "type": "KMS",
      "required": true,
      "defaultConfig": {}
    }
  ],
  "variables": [
    {
      "name": "project_name",
      "description": "Unique name for this deployment (alphanumeric + hyphens)",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "aws_region",
      "description": "AWS region to deploy into",
      "type": "string",
      "default": "us-east-1",
      "required": false
    },
    {
      "name": "aws_profile",
      "description": "AWS CLI named profile",
      "type": "string",
      "default": "default",
      "required": false
    },
    {
      "name": "environment",
      "description": "Deployment environment tag (e.g. dev, staging, prod)",
      "type": "string",
      "default": "dev",
      "required": false
    },
    {
      "name": "container_image",
      "description": "Full ECR image URI including tag",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "image_tag",
      "description": "Container image tag (never 'latest')",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "eks_version",
      "description": "Kubernetes version for the EKS cluster",
      "type": "string",
      "default": "1.31",
      "required": false
    },
    {
      "name": "node_instance_type",
      "description": "EC2 instance type for EKS worker nodes",
      "type": "string",
      "default": "t3.medium",
      "required": false
    },
    {
      "name": "node_count",
      "description": "Desired number of EKS worker nodes",
      "type": "number",
      "default": 2,
      "required": false
    },
    {
      "name": "db_name",
      "description": "Name of the PostgreSQL database to create",
      "type": "string",
      "default": "appdb",
      "required": false
    },
    {
      "name": "db_username",
      "description": "PostgreSQL master username",
      "type": "string",
      "default": "dbadmin",
      "required": false
    },
    {
      "name": "db_instance_class",
      "description": "RDS instance type",
      "type": "string",
      "default": "db.t3.micro",
      "required": false
    },
    {
      "name": "db_allocated_storage",
      "description": "Initial RDS storage in GB",
      "type": "number",
      "default": 20,
      "required": false
    },
    {
      "name": "certificate_arn",
      "description": "ACM certificate ARN for ALB Ingress HTTPS",
      "type": "string",
      "default": null,
      "required": true
    }
  ],
  "securityBaseline": {
    "enableVpcFlowLogs": true,
    "enforceHttps": true
  }
}
