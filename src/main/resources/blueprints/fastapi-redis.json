{
  "blueprintId": "fastapi-redis",
  "displayName": "FastAPI + Redis (ECS Fargate + ElastiCache)",
  "description": "Deploys a FastAPI application on ECS Fargate with an ElastiCache Redis cluster for caching, an Application Load Balancer for HTTPS traffic, and a private VPC. Enforces Redis encryption at rest and in transit, and VPC isolation for the cache.",
  "outputType": "TERRAFORM_ONLY",
  "templateFamily": "ecs",
  "terraformProviderVersion": "5.82.0",
  "lastVerifiedDate": "2026-06",
  "techStack": {
    "language": "Python",
    "framework": "FastAPI",
    "database": "Redis"
  },
  "awsResources": [
    {
      "type": "VPC",
      "required": true,
      "defaultConfig": {
        "cidr": "10.0.0.0/16"
      }
    },
    {
      "type": "ALB",
      "required": true,
      "defaultConfig": {
        "https_only": true
      }
    },
    {
      "type": "ECS_FARGATE",
      "required": true,
      "defaultConfig": {
        "cpu": 512,
        "memory": 1024
      }
    },
    {
      "type": "ELASTICACHE_REDIS",
      "required": true,
      "defaultConfig": {
        "node_type": "cache.t3.micro",
        "num_cache_nodes": 1
      }
    }
  ],
  "variables": [
    {
      "name": "project_name",
      "description": "Unique name for this deployment (alphanumeric + hyphens)",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "aws_region",
      "description": "AWS region to deploy into",
      "type": "string",
      "default": "us-east-1",
      "required": false
    },
    {
      "name": "aws_profile",
      "description": "AWS CLI profile name (PRODUCTION only)",
      "type": "string",
      "default": "default",
      "required": false
    },
    {
      "name": "environment",
      "description": "Deployment environment tag (e.g. dev, staging, prod)",
      "type": "string",
      "default": "dev",
      "required": false
    },
    {
      "name": "container_image",
      "description": "Full ECR image URI including tag",
      "type": "string",
      "default": null,
      "required": true
    },
    {
      "name": "container_port",
      "description": "Port the FastAPI application listens on",
      "type": "number",
      "default": 8000,
      "required": false
    },
    {
      "name": "task_cpu",
      "description": "ECS task CPU units (256, 512, 1024, 2048, 4096)",
      "type": "number",
      "default": 512,
      "required": false
    },
    {
      "name": "task_memory",
      "description": "ECS task memory in MiB",
      "type": "number",
      "default": 1024,
      "required": false
    },
    {
      "name": "desired_count",
      "description": "Number of ECS task instances to run",
      "type": "number",
      "default": 2,
      "required": false
    },
    {
      "name": "redis_node_type",
      "description": "ElastiCache node instance type",
      "type": "string",
      "default": "cache.t3.micro",
      "required": false
    },
    {
      "name": "redis_num_nodes",
      "description": "Number of ElastiCache nodes",
      "type": "number",
      "default": 1,
      "required": false
    },
    {
      "name": "certificate_arn",
      "description": "ACM certificate ARN for ALB HTTPS listener",
      "type": "string",
      "default": null,
      "required": true
    }
  ],
  "securityBaseline": {
    "enableVpcFlowLogs": true,
    "enforceHttps": true
  }
}
